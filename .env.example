# Copy to .env and fill in values. Local development uses SQLite.
# DATABASE_URI: SQLite file URL for local dev (e.g. file:./kartikart.db).
#   In production (Phase 5) this becomes a Postgres connection string.
DATABASE_URI=file:./kartikart.db
# PAYLOAD_SECRET: any long random string used to sign auth tokens.
PAYLOAD_SECRET=YOUR_SECRET_HERE
