# ── Local development (SQLite) ───────────────────────────────────────────────
# Copy this file to `.env` and fill in values. Local dev uses SQLite + local-disk media.
DATABASE_URI=file:./kartikart.db
# Any long random string, e.g. `openssl rand -hex 32`
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ── Production (Vercel) — set these in the Vercel project → Settings → Environment ─
# DATABASE_URI  A Postgres connection string. Use Neon's POOLED URL (ends with
#               `-pooler…` and includes `?sslmode=require`), e.g.
#               postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/kartikart?sslmode=require
# BLOB_READ_WRITE_TOKEN  Set automatically when you add a Vercel Blob store.
# NEXT_PUBLIC_SITE_URL   https://www.kartikart.in  (used for SEO / Open Graph absolute URLs)
